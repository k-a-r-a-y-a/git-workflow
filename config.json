{
    "appName": "Cloud Cost Dashboard",
    "version": "1.1.0",
    "environment": "production",
    "features": {
        "authentication": true,
        "dashboard": true,
        "reports": false
    },
    "api": {
        "endpoint": "https://api.cloudcost.com/v2",
        "timeout": 45
    },
    "auth": {
        "sessionTimeout": 3600,
        "maxLoginAttempts": 5,
        "requireMFA": false
    },
    "dashboard": {
        "refreshInterval": 30,
        "defaultView": "weekly",
        "widgets": ["cost", "savings", "forecast"]
    }
}
